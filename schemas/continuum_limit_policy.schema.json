{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "continuum_limit_policy.schema.json",
  "title": "YM3D Continuum Limit Policy",
  "type": "object",
  "required": [
    "limit_order",
    "requires_joint_uniformity",
    "thermodynamic_gate",
    "continuum_uniformity_gate",
    "continuum_claims_blocked_until"
  ],
  "properties": {
    "limit_order": {
      "enum": [
        "thermodynamic_then_continuum",
        "joint_uniformity"
      ]
    },
    "requires_joint_uniformity": {
      "type": "boolean"
    },
    "thermodynamic_gate": {
      "const": "S6"
    },
    "continuum_uniformity_gate": {
      "const": "S13"
    },
    "continuum_claims_blocked_until": {
      "const": "S13_closed"
    }
  },
  "additionalProperties": false
}