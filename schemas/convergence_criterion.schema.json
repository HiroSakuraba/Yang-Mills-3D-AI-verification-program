{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "convergence_criterion.schema.json",
  "title": "YM3D Convergence Criterion Schema",
  "type": "object",
  "required": [
    "criterion_id",
    "criterion_type",
    "activity_norm_id"
  ],
  "properties": {
    "criterion_id": {
      "type": "string"
    },
    "criterion_type": {
      "enum": [
        "KP",
        "Dobrushin",
        "Fernandez_Procacci",
        "tree_graph",
        "signed_fermionic_cluster",
        "determinant_exact",
        "custom"
      ]
    },
    "activity_norm_id": {
      "type": "string"
    },
    "positive_activity_required": {
      "type": "boolean"
    },
    "ghost_determinant_admissible": {
      "type": "boolean"
    },
    "determinant_sign_certificate_id": {
      "type": "string"
    },
    "absolute_majorant_certificate_id": {
      "type": "string"
    },
    "negative_control_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "criterion_type": {
            "const": "signed_fermionic_cluster"
          }
        }
      },
      "then": {
        "required": [
          "determinant_sign_certificate_id"
        ]
      }
    }
  ]
}