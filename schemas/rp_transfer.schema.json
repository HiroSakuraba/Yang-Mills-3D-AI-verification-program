{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "rp_transfer.schema.json",
  "title": "YM3D Reflection-Positivity Transfer Certificate",
  "type": "object",
  "required": ["gate_id", "required_pipeline", "spatial_factorization_plane"],
  "properties": {
    "gate_id": {"const": "S12_REFLECTION_POSITIVITY_TRANSFER"},
    "required_pipeline": {
      "type": "array",
      "prefixItems": [
        {"const": "gauge_fixed_object"},
        {"const": "haar_averaged_invariant_object"},
        {"const": "reflection_tagged_object"},
        {"const": "os_admissible_object"}
      ],
      "minItems": 4,
      "maxItems": 4
    },
    "spatial_factorization_plane": {
      "type": "object",
      "required": ["plane_id", "axis", "support_relation"],
      "properties": {
        "plane_id": {"type": "string"},
        "axis": {"enum": ["x", "y", "z", "t"]},
        "offset": {"type": "string"},
        "support_relation": {"enum": ["positive_half_space", "negative_half_space", "reflection_symmetric", "crosses_invalid"]},
        "factorization_certificate_id": {"type": ["string", "null"]}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
